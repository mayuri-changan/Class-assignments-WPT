
<html>
<head>
    <title>Perfect Number Check</title>
</head>
<body>

    <h2>Check Perfect Number</h2>

    <form action="/check" method="POST">
        <input type="number" name="number" placeholder="Enter number" required>
        <button type="submit">Check</button>
    </form>

    <% if (result) { %>
        <h3><%= result %></h3>
    <% } %>

</body>
</html>
